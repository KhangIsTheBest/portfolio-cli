# Backend API URL
# In local development: http://localhost:8080
# In production: e.g. https://your-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Google OAuth2 Client ID
# Obtain this from the Google Cloud Console (APIs & Services -> Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
